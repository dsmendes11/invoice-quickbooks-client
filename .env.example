# Copy to .env and fill in real values. docker-compose reads .env automatically.
# Never commit the filled-in .env file.
#
# IMPORTANT: application.yml/application-dev.yml/application-prod.yml bake in NO secret and no
# sandbox credential anymore — every var below is required with no yml-level fallback. Leave one
# blank and the app fails to start with a "could not resolve placeholder" error.
#
# Also note: this file is only auto-read by `docker compose`. If you run the app directly from
# IntelliJ (not via `docker compose up` for the app service), copy these same key/value pairs
# into the Run Configuration's "Environment variables" field instead (or install the IntelliJ
# "EnvFile" plugin and point it at this file) — AND set SPRING_PROFILES_ACTIVE=dev there too
# (docker-compose already defaults this on its own, IntelliJ does not).

# Which application-*.yml profile to activate. docker-compose.yml already defaults this to
# "dev" on its own; only needed here for an IntelliJ Run Configuration reading this file.
SPRING_PROFILES_ACTIVE=dev

# QuickBooks (Intuit developer app credentials + current OAuth tokens)
QUICKBOOKS_API_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QUICKBOOKS_API_REALM_ID=
QUICKBOOKS_API_CLIENT_ID=
QUICKBOOKS_API_CLIENT_SECRET=
QUICKBOOKS_API_ACCESS_TOKEN=
QUICKBOOKS_API_REFRESH_TOKEN=

# Shared "uaa" OAuth2 client registration (icligo's own login.icligo.com SSO)
UAA_CLIENT_ID=
UAA_CLIENT_SECRET=

# Redirect/connect URIs — application-dev.yml already defaults these to the shared dev
# environment (https://dev.invoices.icligo.com/...). Override to localhost here so the OAuth
# "connect" flow works when running this stack on your own machine (see the local-setup
# tutorial, §5.2). Requires that http://localhost:9191/quickbooks/callback also be registered
# as a Redirect URI in the Intuit Developer Dashboard for this app.
QUICKBOOKS_OAUTH_REDIRECT_URI=http://localhost:9191/quickbooks/callback
QUICKBOOKS_OAUTH_CONNECT_URI=http://localhost:9191/quickbooks/connect

# Deposit account for SalesReceipt/RefundReceipt (validated to exist in QuickBooks on every
# creation — not applicable to Invoice, see application.yml comment)
QUICKBOOKS_DEPOSIT_SALES_REFUND_ACCOUNT_NAME=1030 - Stripe/Paypal

# QuickBooks PRODUCTION credentials — READ-ONLY, used only by the sandbox-copy feature
# (POST {api.base-path}/sandbox-copy/{entity}) to pull entities into the sandbox above.
# Leave unset unless you actually need to run a sandbox copy.
QUICKBOOKS_PROD_REALM_ID=
QUICKBOOKS_PROD_CLIENT_ID=
QUICKBOOKS_PROD_CLIENT_SECRET=
QUICKBOOKS_PROD_ACCESS_TOKEN=
QUICKBOOKS_PROD_REFRESH_TOKEN=

# Shared secret other services send as the "auth-token" header — see docs/CLIENT_INTEGRATION.md
AUTH_TOKEN=

# Mailjet (admin disconnect alert — see docs/OPERATIONS.md §5)
MAILJET_PUBLIC_KEY=
MAILJET_PRIVATE_KEY=
